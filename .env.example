# OpenAI API（会話・評価・音声文字起こしに必須）
# https://platform.openai.com/api-keys
#
# ローカル: このファイルを .env.local にコピーして設定（Git 管理外）
# Railway:  Service → Variables に同名で設定（引用符なし推奨）
OPENAI_API_KEY=sk-your-api-key-here

# Prisma / SQLite 接続文字列
DATABASE_URL="file:./prisma/dev.db"

# NODE_ENV は設定しないでください（Next.js / Railway が自動設定します）

# OpenAI API（会話・評価・音声文字起こしに必須）
# https://platform.openai.com/api-keys
#
# ローカル: .env.local に設定（Git 管理外）
# Railway:  Project → Variables に同名で設定
OPENAI_API_KEY=

# Prisma / SQLite 接続文字列
# ローカル: file:./prisma/dev.db
# Railway:  file:/data/prod.db（Volume を /data にマウントする場合）
DATABASE_URL="file:./prisma/dev.db"

# Node 実行環境
# ローカル開発: development
# Railway: production（プラットフォームが自動設定する場合あり）
NODE_ENV=development

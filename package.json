{
  "name": "konkatsu-ai-trainer",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @konkatsu/web dev",
    "build": "pnpm type-check && pnpm --filter @konkatsu/web build",
    "type-check": "pnpm -r run type-check",
    "lint": "pnpm --filter @konkatsu/web lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "engine:cli": "pnpm --filter @konkatsu/conversation-engine cli"
  },
  "devDependencies": {
    "prettier": "^3.9.1",
    "typescript": "^5"
  }
}
